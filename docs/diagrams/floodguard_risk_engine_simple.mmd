%%{init: {"layout": "elk"}}%%
flowchart TB
    A["Rainfall windows"]
    B["River trend"]
    C["Wetness"]
    D["Coverage & freshness"]

    E["Pressure scores"]
    F["Confidence rules"]
    G{"Concern level"}

    H["Low"]
    I["Moderate"]
    J["High"]

    K["Decision audit"]

    A --> E
