    classDef orange stroke:#fb923c,fill:#fff7ed,color:#111827;
    classDef cyan stroke:#22d3ee,fill:#ecfeff,color:#111827;
    classDef green stroke:#4ade80,fill:#f0fdf4,color:#111827;
    classDef amber stroke:#facc15,fill:#fefce8,color:#111827;
    classDef red stroke:#f87171,fill:#fef2f2,color:#111827;

    class A,B,C,D teal;
    class E,F violet;
    class G orange;
    class H green;
    class I amber;
    class J red;
